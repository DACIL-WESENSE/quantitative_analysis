#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DATA_DIR="${1:-$SCRIPT_DIR/data}"

success_count=0
failed_count=0
failed_filenames=""

while IFS= read -r -d '' file; do
    dir="$(dirname "$file")"
    base="$(basename "${file%.*}")"
    csv_filename="$dir/$base.csv"

    if libreoffice --headless --convert-to csv "$file" --outdir "$dir" >/dev/null 2>&1; then
        if [[ -f "$csv_filename" && -s "$csv_filename" ]]; then
            echo "Converted: $file"
            ((success_count++))
        else
            echo "Failed (empty output): $file"
            ((failed_count++))
            failed_filenames+=" $file"
        fi
    else
        echo "Failed: $file"
        ((failed_count++))
        failed_filenames+=" $file"
    fi
done < <(find "$DATA_DIR" -type f \( -iname "*.xls" -o -iname "*.xlsx" \) -print0)

echo ""
echo "Total conversion success count: $success_count"
echo "Total conversion failed count: $failed_count"
if [[ "$failed_count" -gt 0 ]]; then
    echo "Conversion failed filenames:$failed_filenames"
fi
